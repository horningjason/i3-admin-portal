# Portal's own log verbosity (default: INFO)
PORTAL_LOG_LEVEL=INFO

# Path to the multi-node target config (see nodes.json.example). Each entry
# is one FE instance (LVF/ECRF/MCS/GCS/MDS) to persistently SUBSCRIBE to for
# emergency-ElementState / emergency-ServiceState notifications. Nodes
# without sip_host/sip_port are skipped for SIP but still get LogEvents
# attributed to them if their elementId is set. Missing file = no SIP
# watching, LogEvents receiver still works.
PORTAL_NODES_FILE=nodes.json
